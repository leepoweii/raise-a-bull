# provider.env — 額外服務的 API keys
# 複製到 workspace/secrets/provider.env
#
# 注意：AI 模型認證推薦使用 OAuth（不需要填這裡）
# 執行 openclaw models auth login --provider openai-codex 即可
# 詳見 docs/accounts-checklist.md

# OpenAI API Key (選填 — 僅進階使用者需要，OAuth 使用者可略過)
# OPENAI_API_KEY=sk-xxx

# CWA 天氣 API (選填)
CWA_API_KEY=CWA-xxx

# htmlcsstoimage (選填，圖片生成用)
HCTI_USER_ID=
HCTI_API_KEY=
