# Claude Code — must be installed: npm install -g @anthropic-ai/claude-code
CLAUDE_BIN=claude
CLAUDE_MODEL=claude-sonnet-4-6

# Workspace (absolute path to your workspace/ directory)
WORKSPACE=/app/workspace

# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_USER_ID=

# Discord Bot
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Sessions database
DB_PATH=/app/workspace/data/sessions.db

# Heartbeat (v2)
MAX_DAILY_HEARTBEAT_TRIGGERS=20
